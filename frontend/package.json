{
  "name": "pharmago-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:user": "turbo run dev --filter=@pharmago/user-web",
    "dev:pharmacist": "turbo run dev --filter=@pharmago/pharmacist-web",
    "dev:admin": "turbo run dev --filter=@pharmago/admin-web",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "turbo": "^2.0.14",
    "typescript": "^5.8.3"
  },
  "packageManager": "npm@10.9.2"
}

