{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@pharmago/api-client": [
        "packages/api-client/src/index.ts"
      ],
      "@pharmago/auth": [
        "packages/auth/src/client.ts"
      ],
      "@pharmago/auth/client": [
        "packages/auth/src/client.ts"
      ],
      "@pharmago/auth/server": [
        "packages/auth/src/server.ts"
      ],
      "@pharmago/config": [
        "packages/config/src/index.ts"
      ],
      "@pharmago/types": [
        "packages/types/src/index.ts"
      ],
      "@pharmago/ui": [
        "packages/ui/src/index.ts"
      ]
    }
  }
}
